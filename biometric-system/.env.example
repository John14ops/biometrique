# --- SUPABASE ---
SUPABASE_URL=https://iztvgaurvbskjsehjshn.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml6dHZnYXVydmJza2pzZWhqc2huIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk1MzUyNjQsImV4cCI6MjA5NTExMTI2NH0.UQaDACDWi1ZOGiANp4ru7-7Kfu5PCYHp8wDtaVxDMGk
# ⚠️  Remplacer par ta service_role key (Settings > API > service_role) pour le backend
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- APP ---
APP_ENV=development                    # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# --- IA / MODÈLES ---
FACE_DETECTION_MODEL=buffalo_l         # buffalo_l | buffalo_s (rapide)
EMBEDDING_MODEL=arcface_r100           # arcface_r100 | arcface_r50
ANTI_SPOOF_MODEL=minivision
MODEL_DIR=./models
SIMILARITY_THRESHOLD=0.6               # seuil reconnaissance (0.5-0.7)
LIVENESS_THRESHOLD=0.5                 # seuil anti-spoof

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300                          # secondes

# --- STOCKAGE IMAGES (Supabase Storage) ---
STORAGE_BUCKET=biometric-media
MAX_IMAGE_SIZE_MB=5

# --- PERFORMANCE ---
GPU_ENABLED=false                      # true si CUDA disponible
BATCH_SIZE=8
MAX_FACES_PER_FRAME=10
FPS_TARGET=30

# --- SÉCURITÉ ---
JWT_EXPIRE_MINUTES=60
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=100
